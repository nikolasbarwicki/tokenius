{
  "$schema": "./node_modules/oxlint/configuration_schema.json",
  "plugins": ["typescript", "unicorn", "import", "promise", "oxc", "node"],
  "categories": {
    "correctness": "error",
    "suspicious": "warn",
    "pedantic": "warn",
    "perf": "warn",
    "style": "warn"
  },
  "rules": {
    // --- TypeScript strict / restriction rules ---
    "typescript/no-explicit-any": "error",
    "typescript/no-non-null-assertion": "warn",
    "typescript/consistent-type-imports": ["error", { "prefer": "type-imports" }],
    "typescript/no-import-type-side-effects": "error",
    "typescript/no-require-imports": "error",
    "typescript/no-namespace": "error",

    // --- Import rules ---
    "import/first": "error",
    "import/no-duplicates": "error",
    "import/no-self-import": "error",
    "import/no-cycle": "error",
    "import/no-default-export": "warn",
    "import/group-exports": "off",
    "import/no-named-export": "off",

    // --- Sort imports handled by oxfmt's sortImports ---
    "sort-imports": "off",

    // --- Unicorn strict picks ---
    "unicorn/no-null": "off",
    "unicorn/prefer-module": "off",
    "unicorn/no-array-for-each": "warn",
    "unicorn/no-array-reduce": "warn",
    "unicorn/prefer-ternary": "off",

    // --- Promise ---
    "promise/no-return-wrap": "error",

    // --- Turn off rules that conflict with Bun or are too noisy ---
    "unicorn/prefer-node-protocol": "off",
    "no-magic-numbers": "off",
    "no-inline-comments": "off",
    "sort-keys": "off",
    "func-style": "off",
    "import/exports-last": "off",
    "capitalized-comments": "off",
    "id-length": "off",
    "import/prefer-default-export": "off",
    "max-lines-per-function": "off",
    "unicorn/switch-case-braces": "off",
    "max-params": "off",
    "max-statements": "off",
    "no-await-in-loop": "off",
    "prefer-destructuring": "off",
    "init-declarations": "off",
    "unicorn/numeric-separators-style": "off",
    "no-ternary": "off",
    "no-continue": "off",
    "unicorn/prefer-top-level-await": "off",
    "unicorn/prefer-string-raw": "off"
  },
  "env": {
    "builtin": true
  },
  "ignorePatterns": ["dist/", "node_modules/"],
  "overrides": [
    {
      "files": ["*.config.js", "*.config.ts", "*.config.mjs"],
      "rules": {
        "import/no-default-export": "off",
        "import/no-anonymous-default-export": "off"
      }
    }
  ]
}
